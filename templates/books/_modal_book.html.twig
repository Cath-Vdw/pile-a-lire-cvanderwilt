  <!-- ==========================================
      MODALS — Fenêtres contextuelles
      Superposées à la page (position: fixed).
      JavaScript les affiche en ajoutant la classe
      "show" et les ferme en la retirant.
      Les boutons .close-modal (✕) ferment aussi
      la modal active au clic.
  ========================================== -->

  <!-- Modal de détail d'un livre
      Affichée quand l'utilisateur clique sur une carte dans la grille de résultats.
      JavaScript remplit tous les champs (titre, auteur, résumé…) avant de l'ouvrir. -->
  <div id="book-modal" class="modal">
    <div class="modal-content">
      <span class="close-modal">&times;</span>
      <div class="modal-body">

        <div class="book-detail-cover">
          <!-- JavaScript ajoute une classe CSS (ex: genre-fantasy) pour coloriser
              la couverture selon le genre du livre affiché -->
          <div id="detail-cover" class="book-cover"></div>
        </div>

        <div class="book-detail-info">
          <h2 id="detail-title">Titre du livre</h2>
          <p class="detail-author" id="detail-author">Auteur</p>

          <div class="detail-meta">
            <span class="meta-item">
              <strong>Format:</strong>
              <span id="detail-format"></span>
            </span>
            <span class="meta-item">
              <!-- JavaScript remplace le libellé "Pages" par "Durée"
                  quand le livre affiché est un audiobook -->
            <strong id="detail-length-label">Pages:</strong>
              <span id="detail-length"></span>
            </span>
            <span class="meta-item">
              <strong>Genre:</strong>
              <span id="detail-genres"></span>
            </span>
          </div>

          <div class="detail-summary">
            <h3>Résumé</h3>
            <p id="detail-summary">Résumé du livre</p>
          </div>

          <div class="detail-actions">
            <!-- JavaScript met à jour le libellé et l'icône selon que le livre
                  est déjà dans la PAL ou non -->
            <button id="detail-favorite-btn" class="btn btn-modal-action not-in-pile">
              <i data-lucide="star"></i> Ajouter à ma pile
            </button>
          </div>
        </div>
      </div>
    </div>
  </div><!-- /book-modal -->