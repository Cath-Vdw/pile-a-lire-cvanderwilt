<!-- ==========================================
      HOW IT WORKS — Comment ça marche
      4 étapes illustrées présentant le parcours
      utilisateur de la recherche à la notation.
  ========================================== -->
<section id="how-it-works" class="how-it-works">
	<div class="section-container">
		<h2>Comment ça marche?</h2>
		<div
			class="steps-container">
			<!-- Grille de 4 cartes (disposition automatique définie dans le CSS) -->

			<div class="step">
				<div
					class="step-icon">
					<!-- data-lucide="nom" : converti en SVG par lucide.createIcons() -->
					<i data-lucide="search"></i>
				</div>
				<h3>1. Cherchez un livre</h3>
				<p>Filtrez par format, longueur, genre ou mot-clé pour trouver votre prochaine lecture.</p>
			</div>

			<div class="step">
				<div class="step-icon">
					<i data-lucide="star"></i>
				</div>
				<h3>2. Ajoutez à votre pile</h3>
				<p>Cliquez sur l'étoile pour ajouter un livre à votre Pile à Lire.</p>
			</div>

			<div class="step">
				<div class="step-icon">
					<i data-lucide="book"></i>
				</div>
				<h3>3. Gérez votre PAL</h3>
				<p>Organisez, triez, ou archivez vos livres selon votre progression de lecture.</p>
			</div>

			<div class="step">
				<div class="step-icon">
					<i data-lucide="award"></i>
				</div>
				<h3>4. Notez vos lectures</h3>
				<p>Livre terminé? Notez, commentez et marquez vos coups de cœur pour ne jamais les oublier.</p>
			</div>

		</div>
	</div>
</section>
